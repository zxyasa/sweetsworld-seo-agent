# Node / TS service settings
PORT=8787
PUBLISH_MODE=dry_run
DB_PATH=./data/publish.db
BASE_URL=https://sweetsworld.com.au

FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=
X_BEARER_TOKEN=
PINTEREST_ACCESS_TOKEN=
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Python SEO agent settings
WP_BASE_URL=https://sweetsworld.com.au
WP_USERNAME=
WP_APP_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
USE_AI_GENERATION=true

GSC_PROPERTY_URL=https://sweetsworld.com.au
GSC_CREDENTIALS_FILE=gsc_credentials.json
USE_GSC_DATA=false

# Daily SEO publishing workflow
SEO_RUN_MODE=daily
DAILY_LIMIT=1
SEO_STATE_FILE=./data/seo_daily_state.json
AUTO_PUBLISH_CREATED_POSTS=false

# Automatic topics.csv replenishment
AUTO_GENERATE_TOPICS=true
TOPIC_GENERATION_SOURCE=auto
TOPIC_TARGET_PENDING=5
TOPIC_SEEDS=american candy,sour lollies,vegan candy,halal candy

# WordPress category routing for SEO page types
WP_GUIDE_CATEGORY_SLUG=candy-guides
WP_GUIDE_CATEGORY_NAME=Candy Guides
WP_OCCASION_CATEGORY_SLUG=candy-guides
WP_OCCASION_CATEGORY_NAME=Candy Guides
WP_LANDING_CATEGORY_SLUG=where-to-buy
WP_LANDING_CATEGORY_NAME=Where to Buy
WP_CATEGORY_PAGE_CATEGORY_SLUG=products
